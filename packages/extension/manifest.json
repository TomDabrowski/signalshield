{
  "manifest_version": 3,
  "name": "SignalShield",
  "version": "0.1.0",
  "description": "Hide unwanted YouTube and Google Search content using a shared rule engine.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/content/youtube.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.google.com/*"
      ],
      "js": [
        "src/content/google.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/index.html"
}
